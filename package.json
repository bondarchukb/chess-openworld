{
  "name": "chess-openworld",
  "private": true,
  "version": "0.0.0",
  "description": "Open-world multiplayer chess MMO — colorful, data-driven, server-authoritative.",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "predev": "npm run build -w @chess-openworld/protocol",
    "dev": "concurrently -n server,client -c green,cyan \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "npm run start -w @chess-openworld/server",
    "dev:client": "npm run dev -w @chess-openworld/client",
    "share": "concurrently -n server,client,tunnel -c green,cyan,magenta \"npm:dev:server\" \"npm:dev:client\" \"cloudflared tunnel --url http://localhost:5173\""
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  },
  "license": "MIT"
}
